# URL do backend para o proxy do Vite em desenvolvimento.
# Em dev, requisições a /api/* são encaminhadas para este alvo.
VITE_API_PROXY_TARGET=http://localhost:3030

# (Opcional) Se não quiser usar o proxy do Vite, defina a base URL completa
# da API. Quando definido, o client faz fetch direto para este domínio.
# Em produção, o Nginx do EC2 serve /api no mesmo host, então deixe vazio.
# VITE_API_BASE_URL=https://app.roianalyser.com/api
